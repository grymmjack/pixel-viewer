# Generated by Cargo
# will have compiled files and executables
**/debug/*
**/target/*

# These are backup files generated by rustfmt
**/*.rs.bk

# Ignore local Claude state, but track the shared web-session build hook so a
# fresh Claude-Code-on-the-web session can fetch the github git dependency.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/session-start.sh

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb
